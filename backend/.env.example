# osu! OAuth app: https://osu.ppy.sh/home/account/edit#oauth
OSU_CLIENT_ID=your_osu_client_id
OSU_CLIENT_SECRET=your_osu_client_secret
OSU_REDIRECT_URI=http://localhost:8080/auth/osu/callback

# Discord OAuth app, used only for optional account linking: https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:8080/auth/discord/callback

# Where the frontend lives (used for CORS + post-login redirect)
FRONTEND_URL=http://localhost:5173

# Secret used to sign login JWTs, e.g. `openssl rand -hex 32`
JWT_SECRET=change_this_to_a_long_random_string

# Postgres connection string; migrations run automatically on startup
DATABASE_URL=postgres://postgres:postgres@localhost:5432/discord_auth_starter

SERVER_ADDR=127.0.0.1:8080

# Optional: directory containing a built frontend (`npm run build` output) to
# serve as a SPA alongside the API. Unset/missing is fine for local dev where
# the frontend runs separately via `npm run dev`.
# STATIC_DIR=./static
