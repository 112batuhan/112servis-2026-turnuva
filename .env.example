# Project-wide environment. Copy to `.env` and fill in the blanks.
#
# One file, three consumers:
#   • Rust backend   — loaded via dotenvy, which searches parent directories, so
#                      `cargo run` from backend/ finds this file at the repo root.
#   • Vite frontend  — only VITE_-prefixed vars reach the browser (see envDir in
#                      frontend/vite.config.js); the secrets below are never bundled.
#   • docker-compose — variable substitution; compose sets DATABASE_URL and
#                      SERVER_ADDR itself, so those two are only used for local runs.

# osu! OAuth app — https://osu.ppy.sh/home/account/edit#oauth
OSU_CLIENT_ID=your_osu_client_id
OSU_CLIENT_SECRET=your_osu_client_secret
OSU_REDIRECT_URI=http://localhost:8080/auth/osu/callback

# Discord OAuth app, for optional account linking — https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:8080/auth/discord/callback

# Secret for signing login JWTs, e.g. `openssl rand -hex 32`
JWT_SECRET=change_this_to_a_long_random_string

# Postgres connection; migrations run on startup. docker-compose points at its own
# `postgres` service, so this value only matters for a local `cargo run`.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/discord_auth_starter

# --- Optional: the defaults below work for both local dev and Docker as-is. ---
#
# Backend listen address. Local default 127.0.0.1:8080; Docker uses 0.0.0.0:8080.
# SERVER_ADDR=127.0.0.1:8080
#
# Frontend origin for CORS + post-login redirect. Defaults to the Vite dev server
# (http://localhost:5173) locally; the Docker image serves the frontend from the
# backend, so it defaults to http://localhost:8080.
# FRONTEND_URL=http://localhost:5173
#
# Where the frontend calls the API. Unset ⇒ http://localhost:8080 for local dev;
# the Docker image builds it empty so the frontend uses its own origin.
# VITE_API_URL=http://localhost:8080
#
# Directory of a built frontend to serve as a SPA (the Docker image sets this).
# STATIC_DIR=./static
