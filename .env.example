# Used by docker-compose.yml when building/running the app container.
# Copy to `.env` and fill in — same OAuth apps as described in the README,
# but callback URLs should point at wherever this container is reachable.

JWT_SECRET=change_this_to_a_long_random_string

OSU_CLIENT_ID=your_osu_client_id
OSU_CLIENT_SECRET=your_osu_client_secret
OSU_REDIRECT_URI=http://localhost:8080/auth/osu/callback

DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_REDIRECT_URI=http://localhost:8080/auth/discord/callback

# The app serves the frontend itself, so this is just the origin it's reachable at.
FRONTEND_URL=http://localhost:8080

# Leave empty (default) so the frontend calls the API on the same origin it's
# served from. Only set this if the frontend and backend are hosted separately.
VITE_API_URL=
